datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider             = "prisma-client-py"
    interface            = "asyncio"
    recursive_type_depth = 5
}

model User {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    name      String?
    age       Int?      
    createdAt DateTime @default(now())
}

model Time {
    id        Int      @id @default(autoincrement())
    createdAt DateTime @default(now())
}
