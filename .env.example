# Copiar a .env en local o crear en el VPS (nunca commitear .env).
# En producción, DATABASE_URL puede omitirse si DB_* están definidos (compose lo arma).

# --- Client (Vite, solo build-time en imagen prod) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_API_MODE=sync

# --- Server ---
OPENAI_API_KEY=sk-replace-me
PARTNER_SERVICE=AVIADA
CLIENT_APP=SERVIAPP
JWT_SECRET_KEY=replace-with-long-random-secret

# --- PostgreSQL ---
DB_USER=aviada_data
DB_PASSWORD=aviada_secret
DB_NAME=serviguia_db
DB_HOST=db
DB_PORT=5432

# --- Puertos de la VPS (Nuevas) ---
# Define en qué puertos de la VPS escuchará tu app hacia el mundo exterior
CLIENT_PORT=3000
API_PORT=8000